<odoo>
  <data>
    <!-- ========================= -->
    <!-- Leitos: List / Form / Kanban -->
    <!-- ========================= -->

    <record id="view_hospital_leito_list" model="ir.ui.view">
      <field name="name">hospital.leito.list</field>
      <field name="model">hospital.leito</field>
      <field name="arch" type="xml">
        <list>
          <field name="name" />
          <field name="tipo" />
          <field name="status" />
        </list>
      </field>
    </record>

    <record id="view_hospital_leito_form" model="ir.ui.view">
      <field name="name">hospital.leito.form</field>
      <field name="model">hospital.leito</field>
      <field name="arch" type="xml">
        <form string="Leito">
          <sheet>
            <group>
              <field name="name" />
              <field name="tipo" />
              <field name="status" />
            </group>
            <group>
              <field name="observacao" />
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_hospital_leito_kanban" model="ir.ui.view">
      <field name="name">hospital.leito.kanban</field>
      <field name="model">hospital.leito</field>
      <field name="arch" type="xml">
        <kanban default_group_by="status" records_draggable="1">
          <field name="name" />
          <field name="tipo" />
          <field name="status" />
          <templates>
            <t t-name="card">
              <div class="o_kanban_card">
                <div class="o_kanban_record_title">
                  <strong>
                    <field name="name" />
                  </strong>
                </div>
                <div>
                  <span>Tipo: <field name="tipo" /></span>
                </div>
                <div>
                  <span>Status: <field name="status" /></span>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <record id="action_hospital_leito" model="ir.actions.act_window">
      <field name="name">Leitos</field>
      <field name="res_model">hospital.leito</field>
      <field name="view_mode">kanban,list,form</field>
      <field name="context">{'search_default_group_by_status': 1}</field>
    </record>

    <!-- ========================= -->
    <!-- Pacientes: List / Form -->
    <!-- ========================= -->

    <record id="view_hospital_paciente_list" model="ir.ui.view">
      <field name="name">hospital.paciente.list</field>
      <field name="model">res.partner</field>
      <field name="arch" type="xml">
        <list string="Pacientes">
          <field name="name" />
          <field name="data_nascimento" />
          <field name="sexo" />
          <field name="tipo_sanguineo" />
          <field name="status_atendimento" widget="badge"
            decoration-info="status_atendimento == 'em_atendimento'"
            decoration-danger="status_atendimento == 'internado'"
            decoration-success="status_atendimento == 'alta'" />
          <field name="phone" />
        </list>
      </field>
    </record>

    <record id="view_hospital_paciente_form" model="ir.ui.view">
      <field name="name">hospital.paciente.form</field>
      <field name="model">res.partner</field>

      <field name="arch" type="xml">
        <form string="Paciente">

          <header>
            <button name="%(hospital_mgmt.action_report_paciente)d"
              string="Imprimir Relatorio"
              type="action"
              class="btn-primary" />
          </header>

          <sheet>

            <field name="is_patient" invisible="True" />

            <group>
              <group>
                <field name="name" />
                <field name="data_nascimento" />
                <field name="sexo" />
                <field name="tipo_sanguineo" />
              </group>

              <group>
                <field name="email" />
                <field name="phone" />

                <field name="status_atendimento"
                  widget="badge"
                  decoration-info="status_atendimento == 'em_atendimento'"
                  decoration-danger="status_atendimento == 'internado'"
                  decoration-success="status_atendimento == 'alta'" />
              </group>
            </group>

            <notebook>

              <page string="Prontuário Clínico">

                <group>
                  <group string="Alergias e Histórico">
                    <field name="alergias" />
                    <field name="historico_clinico" />
                  </group>

                  <group string="Diagnóstico e Prescrição">
                    <field name="diagnostico" />
                    <field name="prescricao" />
                  </group>
                </group>

                <group>
                  <field name="observacoes" />
                </group>

              </page>

              <page string="Exames e Laudos">
                <field name="laudo_ids" widget="many2many_binary" />
              </page>

            </notebook>

          </sheet>
        </form>
      </field>
    </record>

    <record id="view_res_partner_form_hospital_patient" model="ir.ui.view">
      <field name="name">res.partner.form.hospital.patient</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_form" />
      <field name="arch" type="xml">
        <xpath expr="//field[@name='category_id']" position="after">
          <field name="is_patient" />
        </xpath>
        <xpath expr="//sheet/notebook" position="inside">
          <page string="Paciente" invisible="not is_patient">
            <group>
              <group>
                <field name="data_nascimento" />
                <field name="sexo" />
                <field name="tipo_sanguineo" />
              </group>
              <group>
                <field name="status_atendimento" />
              </group>
            </group>
            <group>
              <group string="Alergias e Histórico">
                <field name="alergias" widget="textarea" />
                <field name="historico_clinico" widget="textarea" />
              </group>
              <group string="Diagnóstico e Prescrição">
                <field name="diagnostico" widget="textarea" />
                <field name="prescricao" widget="textarea" />
              </group>
            </group>
            <group>
              <field name="observacoes" widget="textarea" />
            </group>
          </page>
        </xpath>
      </field>
    </record>

    <record id="action_hospital_paciente" model="ir.actions.act_window">
      <field name="name">Pacientes</field>
      <field name="res_model">res.partner</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[("is_patient", "=", True), ("is_company", "=", False)]</field>
      <field name="context">{'default_is_patient': True, 'default_company_type': 'person',
        'default_status_atendimento': 'em_atendimento'}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Registe o seu primeiro paciente!
        </p>
      </field>
    </record>

    <record id="action_hospital_paciente_list_view" model="ir.actions.act_window.view">
      <field name="sequence" eval="1" />
      <field name="view_mode">list</field>
      <field name="view_id" ref="view_hospital_paciente_list" />
      <field name="act_window_id" ref="action_hospital_paciente" />
    </record>

    <record id="action_hospital_paciente_form_view" model="ir.actions.act_window.view">
      <field name="sequence" eval="2" />
      <field name="view_mode">form</field>
      <field name="view_id" ref="view_hospital_paciente_form" />
      <field name="act_window_id" ref="action_hospital_paciente" />
    </record>


    <!-- ========================= -->
    <!-- Agendamentos: List / Form / Calendar -->
    <!-- ========================= -->

    <record id="view_hospital_agendamento_list" model="ir.ui.view">
      <field name="name">hospital.agendamento.list</field>
      <field name="model">hospital.agendamento</field>
      <field name="arch" type="xml">
        <list string="Agendamentos">
          <field name="paciente_id" />
          <field name="leito_id" />
          <field name="data_inicio" />
          <field name="data_fim" />
          <field name="status" widget="badge"
            decoration-info="status == 'agendado'"
            decoration-warning="status == 'em_uso'"
            decoration-success="status == 'concluido'"
            decoration-danger="status == 'cancelado'" />
        </list>
      </field>
    </record>

    <record id="view_hospital_agendamento_form" model="ir.ui.view">
      <field name="name">hospital.agendamento.form</field>
      <field name="model">hospital.agendamento</field>
      <field name="arch" type="xml">
        <form string="Agendamento de Leito">
          <header>
            <button name="action_confirmar" string="Confirmar Uso"
              type="object" class="btn-primary"
              invisible="status != 'agendado'" />
            <button name="action_liberar" string="Liberar Leito"
              type="object" class="btn-secondary"
              invisible="status != 'em_uso'" />
            <button name="action_cancelar" string="Cancelar"
              type="object" class="btn-danger"
              invisible="status in ('concluido', 'cancelado')" />
            <field name="status" widget="statusbar"
              statusbar_visible="agendado,em_uso,concluido" />
          </header>
          <sheet>
            <group>
              <group>
                <field name="paciente_id" />
                <field name="leito_id" />
              </group>
              <group>
                <field name="data_inicio" />
                <field name="data_fim" />
              </group>
            </group>
            <group>
              <field name="observacoes" widget="textarea" />
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_hospital_agendamento_calendar" model="ir.ui.view">
      <field name="name">hospital.agendamento.calendar</field>
      <field name="model">hospital.agendamento</field>
      <field name="arch" type="xml">
        <calendar string="Agendamentos de Leitos"
          date_start="data_inicio"
          date_stop="data_fim"
          color="leito_id"
          mode="month">
          <field name="paciente_id" />
          <field name="leito_id" />
          <field name="status" />
        </calendar>
      </field>
    </record>

    <record id="action_hospital_agendamento" model="ir.actions.act_window">
      <field name="name">Agendamentos de Leitos</field>
      <field name="res_model">hospital.agendamento</field>
      <field name="view_mode">list,calendar,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crie o primeiro agendamento de leito!
        </p>
      </field>
    </record>

    <!-- ========================= -->
    <!-- Menus -->
    <!-- ========================= -->

    <menuitem id="menu_hospital_root" name="Hospital" sequence="10" />
    <menuitem id="menu_hospital_leitos" name="Leitos" parent="menu_hospital_root"
      action="action_hospital_leito" sequence="20" />
    <menuitem id="menu_hospital_agendamentos" name="Agendamentos" parent="menu_hospital_root"
      action="action_hospital_agendamento" sequence="25" />
    <menuitem id="menu_hospital_pacientes" name="Pacientes" parent="menu_hospital_root"
      action="action_hospital_paciente" sequence="30" />
  </data>
</odoo>